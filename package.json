{
  "name": "vowlms",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.15.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.mjs",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:seed": "prisma db seed",
    "migrate:check-connectivity": "node --use-system-ca --env-file=.env.local scripts/moodle-migration/0-check-connectivity.mjs",
    "migrate:fetch-courses": "node --use-system-ca --env-file=.env.local scripts/moodle-migration/1-fetch-courses.mjs",
    "migrate:fetch-structure": "node --use-system-ca --env-file=.env.local scripts/moodle-migration/2-fetch-structure.mjs",
    "migrate:fetch-content": "node --use-system-ca --env-file=.env.local scripts/moodle-migration/5-fetch-lesson-content.mjs",
    "migrate:fetch-resources": "node --use-system-ca --env-file=.env.local scripts/moodle-migration/6-fetch-resources.mjs",
    "migrate:transform": "node scripts/moodle-migration/3-transform.mjs",
    "migrate:all": "node --use-system-ca --env-file=.env.local scripts/moodle-migration/1-fetch-courses.mjs && node --use-system-ca --env-file=.env.local scripts/moodle-migration/2-fetch-structure.mjs && node scripts/moodle-migration/3-transform.mjs"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.16.0",
    "@react-three/fiber": "^9.0.0",
    "date-fns": "^4.4.0",
    "fuse.js": "^7.4.2",
    "jspdf": "^4.2.1",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.29",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-pdf": "^10.4.1",
    "sonner": "^2.0.7",
    "three": "^0.175.0",
    "tsx": "^4.22.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.175.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prisma": "^6.16.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
